<Window x:Class="vsHelp.UI.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:vsHelp.UI.WPF.ViewModels"
        xmlns:views="clr-namespace:vsHelp.UI.WPF.Views"
        mc:Ignorable="d"
        Title="vsHelp" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        UseLayoutRounding="True">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InstallationsViewModel}">
            <views:InstallationsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:HomologationViewModel}">
            <views:HomologationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:VersionsViewModel}">
            <views:VersionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="{StaticResource SidebarBackgroundBrush}" 
                Grid.Column="0" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Margin="16,24,16,32">
                    <TextBlock Text="vsHelp" 
                               FontSize="16"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="Bold"/>
                    <TextBlock Text="BACKUP" 
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="9"
                               FontWeight="Bold"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Content="Restaurar Backup"
                                 IsChecked="True"
                                 GroupName="SidebarMenu"
                                 Command="{Binding NavigateToRestoreBackupCommand}"/>
                    
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Content="Instalações"
                                 GroupName="SidebarMenu"
                                 Command="{Binding NavigateToInstallationsCommand}"/>
                    
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Content="Homologação"
                                 GroupName="SidebarMenu"
                                 Command="{Binding NavigateToHomologationCommand}"/>
                    
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Content="Versões"
                                 GroupName="SidebarMenu"
                                 Command="{Binding NavigateToVersionsCommand}"/>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,24">
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                 Content="Configurações"
                                 GroupName="SidebarMenu"
                                 Command="{Binding NavigateToSettingsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="{StaticResource AppBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <TextBlock Text="{Binding CurrentViewName, FallbackValue='Restaurar Backup'}" 
                               VerticalAlignment="Center"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Connection Status -->
                        <Border Background="#0D32D74B" CornerRadius="12" Padding="8,3" Margin="0,0,16,0" BorderBrush="#2632D74B" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="localhost:3306" FontSize="10.5" Foreground="{StaticResource SuccessBrush}" FontWeight="Medium"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="v4.0.0" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Background="{StaticResource AppBackgroundBrush}">
                <ContentControl Content="{Binding CurrentView}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
