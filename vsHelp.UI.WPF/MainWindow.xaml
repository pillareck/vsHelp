<Window x:Class="vsHelp.UI.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:vsHelp.UI.WPF.ViewModels"
        xmlns:views="clr-namespace:vsHelp.UI.WPF.Views"
        mc:Ignorable="d"
        Title="vsHelp" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBackgroundBrush}">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InstallationsViewModel}">
            <views:InstallationsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:HomologationViewModel}">
            <views:HomologationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:VersionsViewModel}">
            <views:VersionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="{DynamicResource SidebarBackgroundBrush}" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Margin="16,24,16,24">
                    <TextBlock Text="vsHelp" 
                               FontSize="20"
                               Foreground="White"
                               FontWeight="Bold"/>
                    <TextBlock Text="Backup Manager" 
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="Restaurar Backup"
                            Command="{Binding NavigateToRestoreBackupCommand}"/>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="Instalações"
                            Command="{Binding NavigateToInstallationsCommand}"/>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="Homologação"
                            Command="{Binding NavigateToHomologationCommand}"/>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}"
                                 Content="Versões"
                                 Command="{Binding NavigateToVersionsCommand}"/>
                </StackPanel>

                <!-- Sidebar Footer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Content="Configurações"
                            Command="{Binding NavigateToSettingsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header -->
            <Border Grid.Row="0" Background="{DynamicResource MainBackgroundBrush}" 
                    BorderBrush="#1E1F22" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <TextBlock Text="{Binding CurrentViewName, FallbackValue='Restaurar Backup'}" 
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="White"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
