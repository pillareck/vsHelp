<Application x:Class="vsHelp.UI.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <!-- Paleta de Cores Premium (Raycast/Linear Style) -->
                <ResourceDictionary>
                    <!-- Backgrounds -->
                    <Color x:Key="ColorAppBackground">#0C0C0D</Color>
                    <Color x:Key="ColorSidebarBackground">#141415</Color>
                    <Color x:Key="ColorCardBackground">#19191B</Color>
                    <Color x:Key="ColorInputBackground">#1F1F21</Color>
                    
                    <!-- Borders -->
                    <Color x:Key="ColorBorderDefault">#262629</Color>
                    <Color x:Key="ColorBorderStrong">#323235</Color>
                    
                    <!-- Interaction -->
                    <Color x:Key="ColorHover">#2C2C2E</Color>
                    <Color x:Key="ColorSelection">#3A3A3C</Color>
                    <Color x:Key="ColorAccent">#007AFF</Color>
                    <Color x:Key="ColorAccentGlow">#33007AFF</Color>
                    
                    <!-- Text -->
                    <Color x:Key="ColorTextPrimary">#F5F5F7</Color>
                    <Color x:Key="ColorTextSecondary">#8E8E93</Color>
                    <Color x:Key="ColorTextMuted">#636366</Color>
                    
                    <!-- Status -->
                    <Color x:Key="ColorSuccess">#32D74B</Color>
                    <Color x:Key="ColorWarning">#FFD60A</Color>
                    <Color x:Key="ColorError">#FF453A</Color>

                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorAppBackground}" />
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource ColorSidebarBackground}" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource ColorCardBackground}" />
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource ColorInputBackground}" />
                    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorderDefault}" />
                    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource ColorBorderStrong}" />
                    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource ColorHover}" />
                    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource ColorSelection}" />
                    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
                    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource ColorAccentGlow}" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
                    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}" />
                    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
                    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ColorError}" />
                </ResourceDictionary>

                <ResourceDictionary Source="pack://application:,,,/vsHelp.UI.WPF;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
